	'P':15.*(menp)+mn,
	'S':(menp)*16,
	'Cl':(menp)*17+mn,
	'Fe':(me+mp)*26+mn*29,
	'GRAIN0': 100*6*(menp),
	'GRAIN-': 100*6*(menp)+me,
	'GRAIN+': 100*6*(menp)-me,
	'PAH': 30*6*(menp),
	'PAH-': 30*6*(menp)+me,
	'PAH+': 30*6*(menp)-me,
	'O(1D)':8.*(menp),
