						gammaDb.append(nfidx)
			#build fortran expression for gamma (see Grassi et al. 2011)
			gammaN = "(5.d0*("+(" + ".join(gammaNm)) + ") + 7.d0*("+(" + ".join(gammaNb)) + "))"
			gammaD = "(3.d0*("+(" + ".join(gammaDm)) + ") + 5.d0*("+(" + ".join(gammaDb)) + "))"
			gamma = gammaN + " / &\n" +gammaD
		else: 
			#user-defined gamma
			gamma = typeGamma
		#write gamma
		fout.write("krome_gamma = " + gamma + "\n")
			
	else:
		srow = row.strip()
		if(len(srow)>0):
			if(srow[0]!="#"): fout.write(row)
		else:
			fout.write(row)
if(not(buildCompact)):
	fout.close()
print "done!"

