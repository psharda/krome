reset
#set terminal postscript eps enhanced color font 'Helvetica,10'
#set output 'J21xr_1e-1.eps'
#set multiplot layout 2,1
set logscale
set autoscale
set format y "%L"
set format x "%L"


set key b r
set key Left
set key reverse
set key below
set yrange [7e1:2e4]
set xrange [:1e8]
set ylabel "log(T/K)"
set xlabel "log(density [cm-3])"
n=100
plot './fort.22' u 3:($1==1&&$2==1?$4:1/0) t "J21x=1e-6 J21=0" w l,\
'' u 3:($1==1&&$2==2?$4:1/0) t "J21x=1e-6 J21=5" w l,\
'' u 3:($1==1&&$2==3?$4:1/0) t "J21x=1e-6 J21=10" w l,\
'' u 3:($1==1&&$2==4?$4:1/0) t "J21x=1e-6 J21=50" w l,\
'' u 3:($1==2&&$2==1?$4:1/0) every n t "J21x=1e-2 J21=0",\
'' u 3:($1==2&&$2==2?$4:1/0) every n t "J21x=1e-2 J21=5",\
'' u 3:($1==2&&$2==3?$4:1/0) every n t "J21x=1e-2 J21=10",\
'' u 3:($1==2&&$2==4?$4:1/0) every n t "J21x=1e-2 J21=50"

