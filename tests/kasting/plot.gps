
set multiplot layout 2,2 rowsfirst
set logscale
set autoscale
set format x "%L"
set format y "%L"
set xlabel "log(t/yr)"
set ylabel "log(n/cm-3)"
set key t r
set grid

plot 'fort.66' u 2:3 w l t "H2O"

plot 'fort.66' u 2:5 w l t "OH"

set key b r
plot 'fort.66' u 2:6 w l t "H2"

set key t r
plot 'fort.66' u 2:10 w l t "O2"


unset multiplot
