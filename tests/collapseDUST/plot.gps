reset
set logscale
set autoscale
set format y "%L"
set format x "%L"

set grid
set key b r
set key invert
set xrange [1e-1:]
set ylabel "log(T/K)"
set xlabel "log(n/cm-3)"
plot './fort.22'  u 3:($1==1?$4:1/0):1 w l t "Z=-6",\
 '' u 3:($1==2?$4:1/0):1 w l t "Z=-5",\
 '' u 3:($1==3?$4:1/0):1 w l t "Z=-4",\
 '' u 3:($1==4?$4:1/0):1 w l t "Z=-3",\
 '' u 3:($1==5?$4:1/0):1 w l t "Z=-2",\
  '' u 3:5:1 every 70 w linespo lc var pt 4 ps .4 t "Tdust",\
"<echo '2,2'" w l lc 0 t "Tgas"

