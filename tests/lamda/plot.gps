reset 
set logscale
set autoscale
set format x "%L"
set format y "%L"
set format z "%L"
set ylabel "log(cooling [erg/cm3/s])"
set xlabel "log(Tgas/K)"
set yrange[1e-26:]
set grid
set key reverse
set key Left
set key r b

plot './fort.66' u 1:2 w l t "CI",\
'fort.66' u 1:3 w l t "CII",\
'fort.66' u 1:4 w l t "OI",\
'fort.66' u 1:5 w l t "CO",\
'fort.66' u 1:6 w l t "13CO"