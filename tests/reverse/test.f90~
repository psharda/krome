
!###################################################

program test
  use krome_main !use krome
  use krome_user !use utilities
  implicit none
  integer,parameter::nsp=5 !number of species
  real*8::Tgas,dt,x(nsp),spy,volume,t,xold(nsp)
  integer::i

  call krome_init() !init krome (mandatory)
  volume = 1d3 !cm3
  x(:) = 1d-3*6d23 / volume !mol/cm3

  do i=1,100
     Tgas = (i-1)*(5d3-1d3)/100.+1d3
     write(44,"(99E11.3)") Tgas,krome_get_coeT(Tgas)
  end do
  stop

  Tgas = 4d3 !gas temperature (K)
  dt = 1d-10 !initial time-step (s)
  print *,krome_get_coeT(Tgas)
  t = 0.d0 !time (s)
  do 
     print *,t
     xold(:) = x(:)
     !call the solver
     call krome(x(:), Tgas, dt)
     dt = dt * 1.5d0
     t = t + dt
     write(66,'(99E12.3e3)') t,x(:)/6d23*volume
     if(sum((xold(:)-x(:))**2)<1d-20) exit
  end do

  print *,"Test OK!"
  
end program test

