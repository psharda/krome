-RTOL=1d-2
-maxord=1
-shielding=WG11_withH
-shielding_CO
-shielding_C
-columnDensityMethod=JEANS
-useIndividualFloor=Z
-noRecCheck
-gow
-fixTdust
-computeElectrons
-skipODEthermo
