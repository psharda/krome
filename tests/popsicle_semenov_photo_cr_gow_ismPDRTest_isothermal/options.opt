#options for one-zone ISM equilibrium tests

-n networks/react_popsicle_semenov_photo_cr_gow
-cooling=H2,CONT,CHEM,CI,CII,OI,CO,ATOMIC,COMPTON,DUSTSEMENOV,FF,NEBULAR,Z_CIEGF,DUSTGRREC
-heating=CHEM,PHOTODUSTWD,CR,PHOTOAV
