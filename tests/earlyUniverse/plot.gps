#!/bin/bash

reset
set multiplot layout 2,2 rowsfirst
set logscale
set autoscale
set format x "%L"
set format y "%L"
set ylabel "log(ni/ntot)"
set xlabel "log(1+z)"
set key b l
set key font ",7"
set key spacing 0.8
set key samplen 1
set grid
set xrange [1e1:1.e4] reverse
#set size square

set yrange [1e-25:1e1]
plot './fort.22' u 1:7  w l t "H",\
'' u 1:5  w l t "H+",\
'' u 1:8  w l t "H-",\
'' u 1:9  w l t "H2",\
'' u 1:10  w l t "H2+",\
'' u 1:11  w l t "H3+"

set key b r
set yrange [1e-25:1e1]
plot './fort.22' u 1:14 w l t "He",\
'' u 1:13 w l t "He+",\
'' u 1:12 w l t "He++",\
'' u 1:15 w l t "HeH+"

set yrange [1e-25:1e1]
set key b l
plot './fort.22' u 1:17 w l t "D",\
'' u 1:16 w l t "D+",\
'' u 1:18 w l t "HD",\
'' u 1:19 w l t "HD+",\
'' u 1:20 w l t "H2D+"

set ylabel "log(T[K])"
set xlabel "log(1+z)"
set yrange [1e0:1e4]
set key t r
plot './fort.22' u 1:3 w l t "TGAS",\
'' u 1:4 w l t "TCMB"

unset multiplot
