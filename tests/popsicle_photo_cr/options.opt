#options for test collapse
#Do not include OII cooling because Kim+2023 ApJS include it in NEBULAR

-n networks/react_popsicle_photo_cr
-cooling=H2,CONT,CHEM,CI,CII,OI,HD,CO,OH,H2O,ATOMIC,COMPTON,DUST,FF,NEBULAR
-heating=COMPRESS,CHEM,PHOTODUSTNETWD,CR
-H2opacity=OMUKAI
-gamma=EXACT
-ATOL=1d-40
-maxord=1
-columnDensityMethod=JEANS
-useIndividualFloor=Z
-dust=1,C
-dustOptions=dT,H2
-n networks/react_popsicle_photo_cr
