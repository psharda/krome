
set multiplot layout 2,2 rowsfirst
set logscale
set autoscale
set format x "%L"
set format y "%L"
set format z "%L"
set key b l
set grid

set xlabel "[FK1]"
set ylabel "[FK2]"
plot 'fort.66' u 2:3 w l t "", 'fort.77' u 2:3 w l t "SM"

set xlabel "[FK1]"
set ylabel "[FK3]"
plot 'fort.66' u 2:4 w l t "", 'fort.77' u 2:4 w l t "SM"

set xlabel "[FK2]"
set ylabel "[FK3]"
plot 'fort.66' u 3:4 w l t "", 'fort.77' u 3:4 w l t "SM"

set key t r
set xlabel "[FK1]"
set ylabel "[FK2]"
set zlabel "[FK3]"
splot 'fort.66' u 2:3:4 w l t "", 'fort.77' u 2:3:4 w l t "SM"


unset multiplot
