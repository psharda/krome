	s = """
n(idx_dummy) = 1.d0
n(idx_g) = 1.d0
n(idx_CR) = 1.d0
"""

	s += "do i=1,nrea\n"
	if(use_reduction): s += "if(arr_u(i)==0) cycle\n"
       	s += """
       r1 = arr_r1(i)
       r2 = arr_r2(i)
       r3 = arr_r3(i)
       p1 = arr_p1(i)
       p2 = arr_p2(i)
       p3 = arr_p3(i)
       p4 = arr_p4(i)
       rr = k(i)*n(r1)*n(r2)*n(r3)
