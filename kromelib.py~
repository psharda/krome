def file_exists(fname):
	import os
	return os.path.exists(fname)
##################################
def store_file(fname):
	fh = open(fname,"rb")
	fle = []
	for x in fh:
		fle.append(x)
	fh.close()
	return fle

##################################
def restore_file(fname,fle):
	fout = open(fname,"w")
	for x in fle:
		fout.write(x)
	fout.close()

