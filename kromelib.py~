def truncF90(mystr, sublen, sep):
	#split (&\n) the string mystr in parts smaller tha sublen using sep as separator
	if(mystr.strip()==""): return mystr
	mystr = mystr.replace("**","##")	
	astr = mystr.split(sep)
	s = z = ""
	first = True
	for x in astr:
		if(len(z+x)>sublen and not(first)):
			s += "&\n"
			z = ""
		zep = sep
		if(first): zep = "" 
		s += zep + x
		z += zep + x
		first = False
	return s.replace("##","**")	


