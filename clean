#!/usr/bin/python
#!python
import glob
import os
os.chdir(".")

hasrm = False
#clean all files with give extention
for x in [".log","~",".pyc",".dot",".gps"]:
	for files in glob.glob("*"+x):
		os.unlink(files)
		print "removing "+files
		hasrm = True

#remove temp files (~) from subfolders
for root, dirnames, filenames in os.walk('.'):
	for fle in filenames:
		if(fle[len(fle)-1]=="~"):
			fname = root+"/"+fle 
			os.unlink(fname)
			print "removing "+fname
			hasrm = True

#add README file in build if not present
fname = "build/README"
try:
   with open(fname):
       pass
except IOError:
	print "adding README in build"
	fout = open(fname,"w")
	fout.write("this folder will contains the built files\n")
	fout.close()

if(not(hasrm)): print "nothing to clean"
print "done!"
