@prods: O
@limits:
@rate: dust_desorption_rate(ice_fraction(auto_jdust-nmols),1.7d3,1.7d3,krome_dust_T(auto_jdust-nmols))

#Desorption rate for O2 from Hollenbach+McKee 1979, Cazaux+2010, Hocuk+2014
