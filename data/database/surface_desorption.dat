@var:[ndust] ice_fraction = dust_ice_fraction_array(krome_dust_asize2(:),n(nmols+1:nmols+ndust),n(idx_H2O_dust_1:idx_H2O_dust_1+nmols))


#Desorption rate for H from Hollenbach+McKee 1979, Cazaux+2010, Hocuk+2014
@type: desorption
@reacts: H_dust
@prods: H
@limits:
@rate: dust_desorption_rate(ice_fraction(auto_jdust-nmols),6.5d2,5d2,krome_dust_T(auto_jdust-nmols))

#Desorption rate for H2 from Hollenbach+McKee 1979, Cazaux+2010, Hocuk+2014
@type: desorption
@reacts: H2_dust
@prods: H2
@limits:
@rate: dust_desorption_rate(ice_fraction(auto_jdust-nmols),3d2,3d2,krome_dust_T(auto_jdust-nmols))

#Desorption rate for O from Hollenbach+McKee 1979, Cazaux+2010, Hocuk+2014
@type: desorption
